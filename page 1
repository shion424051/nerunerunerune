<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Task Scale | グループ作成</title>
  <link rel="stylesheet" href="home.css">
</head>
<body class="page-home">
  <main class="home-stage">
    <section class="logo-area" aria-label="Task Scale">
      <div class="scale-logo" aria-hidden="true">
        <div class="scale-beam"></div>
        <div class="scale-post"></div>
        <div class="scale-base"></div>
        <div class="scale-pan left"></div>
        <div class="scale-pan right"></div>
        <strong>TASK SCALE</strong>
      </div>
      <div id="homeGroupCards" class="home-group-cards" aria-label="作成したグループ"></div>
    </section>

    <button id="openCreatePanel" class="round-add home-plus" type="button" aria-label="グループ作成を開く">+</button>

    <aside id="createPanel" class="create-panel" aria-label="グループ作成" aria-hidden="true">
      <div class="phone-card">
        <div class="phone-title">
          <h1>グループ名</h1>
          <a href="main.html">作成</a>
        </div>
        <input id="panelGroupName" class="soft-input" type="text" placeholder="name...">

        <h2>メンバー</h2>
        <div id="homeMemberList" class="home-member-list"></div>

        <button id="addMemberLine" class="tiny-link" type="button">追加</button>

        <form id="homeMemberForm" class="add-person-row">
          <span class="avatar small" aria-hidden="true"></span>
          <input id="newMemberName" class="soft-input" type="text" placeholder="name..." required>
        </form>
      </div>
    </aside>
  </main>

  <script src="home.js"></script>
</body>
</html>

home.css
:root {
  --ink: #667387;
  --ink-dark: #536276;
  --paper: #ffffff;
  --pink: #dccbd1;
  --pink-soft: #eadfe2;
  --lavender: #aca6b4;
  --cream: #f3f0ea;
  --line: #6d788b;
  --shadow: 0 18px 40px rgba(83, 98, 118, 0.12);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  background: var(--paper);
  color: var(--ink);
  font-family: "Yu Gothic UI", "Hiragino Maru Gothic ProN", "Segoe UI", sans-serif;
  font-weight: 800;
  letter-spacing: 0;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input {
  color: inherit;
  font: inherit;
}

button {
  cursor: pointer;
}

input {
  border: 0;
  outline: 0;
}

.home-stage {
  display: grid;
  grid-template-columns: 1fr;
  min-height: 100vh;
  padding: clamp(18px, 3vw, 40px);
  position: relative;
}

.logo-area {
  display: grid;
  gap: 28px;
  grid-template-rows: 1fr auto;
  place-items: center;
  min-height: calc(100vh - 80px);
}

.scale-logo {
  height: min(30vw, 270px);
  min-height: 220px;
  position: relative;
  width: min(42vw, 520px);
}

.home-group-cards {
  display: grid;
  min-height: 82px;
  place-items: center;
  width: min(560px, 92vw);
}

.group-card {
  align-items: center;
  background: linear-gradient(135deg, rgba(234, 223, 226, 0.88), rgba(243, 240, 234, 0.96));
  border: 3px solid rgba(109, 120, 139, 0.3);
  border-radius: 18px;
  box-shadow: var(--shadow);
  display: flex;
  gap: 18px;
  min-height: 76px;
  padding: 14px 22px;
  width: 100%;
}

.group-card-dot {
  background: #f4a5a1;
  border-radius: 999px;
  flex: 0 0 auto;
  height: 42px;
  width: 42px;
}

.group-card strong {
  color: var(--ink-dark);
  display: block;
  font-size: 1.45rem;
  line-height: 1.1;
}

.group-card small {
  color: #9d94a4;
  display: block;
  font-size: 0.92rem;
  margin-top: 4px;
}

.scale-logo strong {
  color: var(--ink-dark);
  font-size: clamp(2.6rem, 5.2vw, 5rem);
  left: 50%;
  line-height: 1;
  position: absolute;
  text-align: center;
  top: 44%;
  transform: translate(-50%, -50%);
  white-space: nowrap;
}

.scale-beam,
.scale-post,
.scale-base,
.scale-pan {
  background: var(--ink);
  position: absolute;
}

.scale-beam {
  border-radius: 36px 36px 10px 10px;
  height: 30px;
  left: 24%;
  top: 25%;
  transform: rotate(1deg);
  width: 52%;
}

.scale-post {
  border-radius: 18px;
  height: 190px;
  left: calc(50% - 12px);
  top: 25%;
  width: 24px;
}

.scale-base {
  border-radius: 12px;
  bottom: 18px;
  height: 24px;
  left: 42%;
  width: 16%;
}

.scale-pan {
  border-radius: 0 0 90px 90px;
  height: 48px;
  top: 70%;
  width: 108px;
}

.scale-pan.left {
  left: 23%;
}

.scale-pan.right {
  right: 23%;
}

.scale-pan::before {
  background: var(--ink);
  content: "";
  height: 78px;
  left: 14px;
  position: absolute;
  top: -72px;
  transform: skewX(-28deg);
  width: 30px;
}

.scale-pan::after {
  background: var(--ink);
  content: "";
  height: 78px;
  position: absolute;
  right: 14px;
  top: -72px;
  transform: skewX(28deg);
  width: 30px;
}

.create-panel {
  align-items: start;
  background: rgba(255, 255, 255, 0.78);
  display: grid;
  inset: 0;
  justify-items: end;
  opacity: 0;
  padding: clamp(96px, 10vw, 120px) clamp(18px, 3vw, 40px) 30px;
  pointer-events: none;
  position: fixed;
  transition: opacity 180ms ease;
  z-index: 8;
}

.create-panel.is-open {
  opacity: 1;
  pointer-events: auto;
}

.round-add {
  align-items: center;
  background: white;
  border: 8px solid var(--line);
  border-radius: 999px;
  color: var(--line);
  display: flex;
  font-size: 3.8rem;
  height: 72px;
  justify-content: center;
  line-height: 0.8;
  margin-bottom: 14px;
  width: 72px;
}

.home-plus {
  position: fixed;
  right: clamp(22px, 4vw, 54px);
  top: clamp(18px, 3vw, 36px);
  z-index: 12;
}

.phone-card {
  border: 7px solid var(--line);
  border-radius: 28px;
  box-shadow: var(--shadow);
  min-height: 590px;
  padding: 20px;
  position: relative;
  width: min(440px, 100%);
}

.phone-title {
  align-items: center;
  display: flex;
  gap: 16px;
  justify-content: space-between;
}

.phone-title h1,
.phone-card h2 {
  font-size: clamp(1.8rem, 3vw, 3rem);
  line-height: 1;
  margin: 0;
}

.phone-title a {
  font-size: 1.35rem;
}

.soft-input {
  background: var(--pink-soft);
  border-radius: 4px;
  font-size: 1.05rem;
  min-height: 44px;
  padding: 8px 14px;
  width: 100%;
}

.phone-card > .soft-input {
  margin: 16px 0 28px;
}

.home-member-list {
  display: grid;
  gap: 14px;
  margin-top: 16px;
  min-height: 160px;
  max-height: 270px;
  overflow: auto;
  padding-right: 4px;
}

.empty-note {
  align-self: center;
  color: #9d94a4;
  font-size: 1.1rem;
  margin: 0;
}

.member-line {
  align-items: center;
  display: flex;
  gap: 18px;
}

.member-name-input {
  background: rgba(234, 223, 226, 0.72);
  border-radius: 10px;
  color: var(--ink-dark);
  font-size: 1.35rem;
  min-height: 42px;
  padding: 8px 12px;
  width: min(230px, 100%);
}

.avatar {
  background: var(--pink);
  border-radius: 999px;
  display: block;
  flex: 0 0 auto;
  height: 68px;
  overflow: hidden;
  position: relative;
  width: 68px;
}

.avatar::before {
  background: white;
  border-radius: 48% 48% 46% 46%;
  content: "";
  height: 30px;
  left: 22px;
  position: absolute;
  top: 20px;
  width: 25px;
}

.avatar::after {
  background: white;
  border-radius: 50% 50% 12% 12%;
  bottom: -5px;
  content: "";
  height: 34px;
  left: 16px;
  position: absolute;
  width: 36px;
}

.avatar.small {
  height: 54px;
  width: 54px;
}

.tiny-link {
  background: transparent;
  border: 0;
  display: block;
  font-size: 1.05rem;
  margin: 20px 0 18px auto;
  text-decoration: underline;
}

.add-person-row {
  align-items: center;
  bottom: 20px;
  display: flex;
  gap: 18px;
  left: 20px;
  position: absolute;
  right: 20px;
}

@media (max-width: 1000px) {
  .home-stage {
    grid-template-columns: 1fr;
  }

  .logo-area {
    min-height: auto;
  }

  .create-panel {
    justify-items: stretch;
  }

  .phone-card {
    width: 100%;
  }
}

@media (max-width: 620px) {
  .home-stage {
    padding: 18px;
  }

  .phone-card {
    border-width: 7px;
    min-height: 560px;
    padding: 20px;
  }
}
home.js
const defaultState = {
  groupName: "グループ名",
  members: [],
  tasks: []
};

const storageKey = "task-scale-rough-v2";
let state = loadState();

function clone(value) {
  return JSON.parse(JSON.stringify(value));
}

function loadState() {
  const saved = localStorage.getItem(storageKey);
  if (!saved) return clone(defaultState);

  try {
    const parsed = JSON.parse(saved);
    return {
      groupName: parsed.groupName || defaultState.groupName,
      members: Array.isArray(parsed.members) ? parsed.members : clone(defaultState.members),
      tasks: Array.isArray(parsed.tasks) ? parsed.tasks : clone(defaultState.tasks)
    };
  } catch {
    return clone(defaultState);
  }
}

function saveState() {
  localStorage.setItem(storageKey, JSON.stringify(state));
}

function uid(prefix) {
  if (window.crypto?.randomUUID) return crypto.randomUUID();
  return `${prefix}-${Date.now()}-${Math.random().toString(16).slice(2)}`;
}

function syncGroupName(value) {
  state.groupName = value.trim() || "グループ名";
  saveState();
  renderHome();
}

function addMember(name = "") {
  const cleanName = name.trim() || `name${state.members.length + 1}`;
  state.members.push({ id: uid("m"), name: cleanName });
  saveState();
  renderHome();
}

function renameMember(memberId, name) {
  const member = state.members.find((item) => item.id === memberId);
  if (!member) return;
  member.name = name.trim() || member.name;
  saveState();
  renderHome();
}

function renderHome() {
  const panelGroupName = document.querySelector("#panelGroupName");
  const memberList = document.querySelector("#homeMemberList");
  const groupCards = document.querySelector("#homeGroupCards");
  if (!panelGroupName || !memberList) return;

  panelGroupName.value = state.groupName === "グループ名" ? "" : state.groupName;

  if (groupCards) {
    const hasGroup = state.groupName !== "グループ名" || state.members.length > 0 || state.tasks.length > 0;
    groupCards.innerHTML = hasGroup ? `
      <a class="group-card" href="main.html">
        <span class="group-card-dot" aria-hidden="true"></span>
        <span>
          <strong>${state.groupName}</strong>
          <small>${state.members.length}人 / ${state.tasks.length}タスク</small>
        </span>
      </a>
    ` : "";
  }

  memberList.innerHTML = state.members.length
    ? state.members.map((member) => `
    <div class="member-line">
      <span class="avatar" aria-hidden="true"></span>
      <input class="member-name-input" data-member-name="${member.id}" value="${member.name}" aria-label="${member.name}の名前">
    </div>
  `).join("")
    : `<p class="empty-note">メンバーを追加してください</p>`;

  document.querySelectorAll("[data-member-name]").forEach((input) => {
    input.addEventListener("change", () => renameMember(input.dataset.memberName, input.value));
  });
}

function bindEvents() {
  document.querySelector("#panelGroupName")?.addEventListener("input", (event) => {
    syncGroupName(event.target.value);
  });

  document.querySelector("#openCreatePanel")?.addEventListener("click", () => {
    const panel = document.querySelector("#createPanel");
    panel?.classList.toggle("is-open");
    panel?.setAttribute("aria-hidden", panel.classList.contains("is-open") ? "false" : "true");
  });

  document.querySelector("#addMemberLine")?.addEventListener("click", () => addMember());

  document.querySelector("#homeMemberForm")?.addEventListener("submit", (event) => {
    event.preventDefault();
    const input = document.querySelector("#newMemberName");
    addMember(input.value);
    input.value = "";
  });

  document.querySelectorAll("[data-member-add-form]").forEach((form) => {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      addMember(String(formData.get("memberName")));
      form.reset();
    });
  });
}

bindEvents();
renderHome();
